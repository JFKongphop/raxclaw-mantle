# ════════════════════════════════════════════════════════════════════════════════
# RAXC Environment Configuration
# ════════════════════════════════════════════════════════════════════════════════
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# ════════════════════════════════════════════════════════════════════════════════

# ─── OpenAI (LLM + Embeddings) ──────────────────────────────────────────────────
# Get your API key at: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini       # or gpt-4o

# ─── Qdrant Vector Database ────────────────────────────────────────────────────
# Create a free cluster at: https://cloud.qdrant.io
QDRANT_ENDPOINT=https://xxx.cloud.qdrant.io
QDRANT_API_KEY=your-qdrant-api-key

# ─── Mantle Sepolia (RaxcAgentERC8004) ──────────────────────────────────────────
# Public RPC (free): https://rpc.sepolia.mantle.xyz
MANTLE_SEPOLIA=https://rpc.sepolia.mantle.xyz
PRIVATE_KEY=0x...              # Wallet private key (needs MNT for gas)
AGENT_ERC8004=0x...            # Deployed RaxcAgentERC8004 contract address

# ─── WebSocket ─────────────────────────────────────────────────────────────────
WS_PORT=3001                   # Server port
